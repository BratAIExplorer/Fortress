# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/fortress

# NextAuth (required)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Email Service (required for signup/email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@fortressintelligence.space

# Scanner (required for Fortress 30 data population)
CRON_SECRET=generate-with-openssl-rand-base64-32
MASSIVE_API_KEY=your-massive-market-data-api-key

# Optional: Scanner base URL (defaults to http://localhost:3000)
SCANNER_BASE_URL=http://localhost:3000
